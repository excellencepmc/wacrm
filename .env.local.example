# ============================================================
# REQUIRED — the app won't start without these.
# ============================================================

# PostgreSQL connection string — point to your existing Postgres server.
# For the CasaSindhu EC2 deployment:
#   DATABASE_URL=postgresql://daleepkumar:<password>@localhost:5432/wacrm
DATABASE_URL=postgresql://user:password@localhost:5432/wacrm

# NextAuth secret — generate with: openssl rand -hex 32
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000

# WhatsApp token encryption (64 hex chars = 32 bytes, AES-256-GCM).
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-char-hex-key-here

# Meta App Secret (Meta for Developers → App Settings → Basic).
META_APP_SECRET=your-meta-app-secret

# ============================================================
# OPTIONAL
# ============================================================

# Public URL of this deployment.
NEXT_PUBLIC_SITE_URL=https://crm.example.com

# Cron secret for automation wait steps.
# AUTOMATION_CRON_SECRET=generate-a-long-random-string
